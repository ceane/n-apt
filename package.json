{
  "name": "n-apt",
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "predev": "pkill -f n-apt-backend || true",
    "preserver": "cargo build --release --bin n-apt-backend",
    "capture": "source venv/bin/activate && python scripts/rtl_sdr_capture.py",
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "./start_server.sh",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "echo \"ALSO INSTALLING RUST DEPS\" && cargo build --release",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:rust": "cargo test",
    "test:all": "npm run test && npm run test:rust"
  },
  "dependencies": {
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "gsap": "^3.14.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.6.0",
    "styled-components": "^6.3.8",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "vite": "^7.2.4"
  }
}
