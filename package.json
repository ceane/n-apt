{
  "name": "n-apt",
  "version": "0.2.5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "pkill -f n-apt-backend || true",
    "preserver": "cargo build --release --bin n-apt-backend",
    "capture": "source venv/bin/activate && python scripts/rtl_sdr_capture.py",
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "./start_server.sh",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "echo \"ALSO INSTALLING RUST DEPS\" && cargo build --release",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:rust": "cargo test",
    "test:all": "npm run test && npm run test:rust",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 10",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "gsap": "^3.14.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.6.0",
    "styled-components": "^6.3.8",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.2",
    "eslint": "^8.45.0",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vite": "^7.2.4"
  }
}
