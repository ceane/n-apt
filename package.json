{
  "name": "n-apt",
  "version": "0.2.5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "fkill --force 'n-apt-backend' ':5173' ':8765' 2>/dev/null || true",
    "preserver": "./start_server.sh",
    "capture": "source venv/bin/activate && python scripts/rtl_sdr_capture.py",
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "./start_server.sh",
    "build:wasm": "./build_wasm.sh",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "postinstall": "echo \"ALSO INSTALLING RUST DEPS\" && ./start_server.sh --build-only",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:wasm": "PATH=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/bin:$PATH sh -lc 'cd tests/wasm && wasm-pack test --headless --chrome'",
    "test:rust": "cargo test",
    "test:all": "npm run test && npm run test:rust",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "gsap": "^3.14.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.6.0",
    "n_apt_canvas": "file:./packages/n_apt_canvas",
    "styled-components": "^6.3.8",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@webgpu/types": "^0.1.47",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.2",
    "fkill-cli": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "oxlint": "^0.10.0",
    "oxfmt": "^0.1.0",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vite": "^7.2.4"
  }
}
