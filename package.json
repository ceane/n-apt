{
  "name": "n-apt",
  "version": "0.2.5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "preserver": "./scripts/deployment/start_server.sh",
    "capture": "source venv/bin/activate && python scripts/visualization/rtl_sdr_capture.py",
    "decrypt-modules": "npx tsx scripts/encrypted-modules/crypt.ts decrypt",
    "encrypt-modules": "npx tsx scripts/encrypted-modules/crypt.ts encrypt",
    "dev": "npm run decrypt-modules || true && npm --silent run build_orchestrator:inner",
    "dev:rezi": "npm --silent run build_orchestrator:rezi",
    "dev:visual": "npm --silent run build_orchestrator:inner",
    "dev:visual-demo": "npm --silent run simple_visual_build:inner",
    "dev:visual-demo:animate": "npm --silent run simple_visual_build:animate:inner",
    "build_orchestrator:inner": "./scripts/build/build_orchestrator.sh",
    "build_orchestrator:rezi": "cd scripts && npx tsx --tsconfig tsconfig.rezi.json rezi_build_image.tsx",
    "simple_visual_build:inner": "./scripts/visualization/simple_visual_build.sh",
    "simple_visual_build:animate:inner": "./scripts/visualization/simple_visual_build.sh --animate",
    "server": "./scripts/deployment/start_server.sh",
    "server:dev": "./scripts/deployment/start_server.sh --dev",
    "server:build": "./scripts/deployment/start_server.sh --build-only",
    "build:dev:backend": "cargo build --bin n-apt-backend",
    "build:rust": "cargo build --release --bin n-apt-backend",
    "build:frontend": "vite build",
    "build:wasm": "./scripts/build/build_wasm.sh",
    "build": "npm run build:backend && npm run build:frontend && npm run build:wasm",
    "preview": "vite preview --port 5174",
    "postinstall": "sh -c 'if [ -n \"$CI\" ]; then echo \"Skipping backend build during CI postinstall\"; else echo \"ALSO INSTALLING RUST DEPS\" && ./scripts/deployment/start_server.sh --build-only; fi'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:wasm": "PATH=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/bin:$PATH sh -lc 'cd test/wasm && wasm-pack test --headless --chrome'",
    "test:rust": "cargo test",
    "test:all": "npm run test && npm run test:rust",
    "test:iq-capture": "./scripts/test/integration/run-iq-capture-tests.sh",
    "test:iq-capture:install": "./scripts/test/integration/run-iq-capture-tests.sh --install",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:fix:rust": "cargo fix --bin \"n-apt-backend\" -p n-apt-backend --allow-dirty --allow-no-vcs",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write src/ts src/rs test",
    "format:check": "oxfmt --check src/ts src/rs test",
    "towers:load:redis": "node scripts/data/load_towers_to_redis.cjs",
    "towers:load:all": "node scripts/data/load_all_towers_to_redis.cjs",
    "towers:load:region": "node scripts/data/load_region_towers.cjs",
    "towers:download:opencellid": "node scripts/data/download_opencellid.cjs",
    "towers:download:cached": "node scripts/data/download_opencellid_cached.cjs",
    "towers:process:opencellid": "node scripts/data/process_opencellid.cjs",
    "towers:db:stats": "node scripts/data/tower_db_manager.cjs stats",
    "towers:db:query": "node scripts/data/tower_db_manager.cjs query",
    "towers:db:backup": "node scripts/data/tower_db_manager.cjs backup",
    "redis:start": "./scripts/data/setup_redis.sh start",
    "redis:stop": "./scripts/data/setup_redis.sh stop",
    "redis:restart": "./scripts/data/setup_redis.sh restart",
    "redis:status": "./scripts/data/setup_redis.sh status",
    "redis:persistent": "./scripts/data/redis_persistent_manager.sh",
    "redis:snapshot": "./scripts/data/redis_persistent_manager.sh snapshot",
    "redis:export": "./scripts/data/redis_persistent_manager.sh export",
    "ladle": "ladle serve",
    "build-ladle": "ladle build"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@rezi-ui/core": "^0.1.0-alpha.52",
    "@rezi-ui/jsx": "^0.1.0-alpha.52",
    "@rezi-ui/node": "^0.1.0-alpha.52",
    "framer-motion": "^12.34.0",
    "gsap": "^3.14.2",
    "icodec": "^0.6.0",
    "katex": "^0.16.35",
    "libheif-js": "^1.19.8",
    "lucide-react": "^0.577.0",
    "n_apt_canvas": "file:./packages/n_apt_canvas",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-katex": "^3.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.0",
    "redis": "^4.7.1",
    "styled-components": "^6.3.8",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/react-katex": "^3.0.4",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@webgpu/types": "^0.1.47",
    "concurrently": "^9.2.1",
    "fkill-cli": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "playwright": "^1.58.2",
    "resize-observer-polyfill": "^1.5.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}
