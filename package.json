{
  "name": "n-apt",
  "version": "0.2.5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "fkill --force 'n-apt-backend' ':5173' ':8765' 2>/dev/null || true",
    "predev:fast": "fkill --force 'n-apt-backend' ':8765' 2>/dev/null || true",
    "predev:hot": "fkill --force 'n-apt-backend' ':8765' 2>/dev/null || true",
    "preserver": "./start_server.sh",
    "capture": "source venv/bin/activate && python scripts/rtl_sdr_capture.py",
    "dev": "concurrently \"npm run build:wasm 2>&1 | grep -E 'error:|warning:|failed' || true\" \"npm run server:dev\" \"vite 2>&1 | grep -v 'ECONNREFUSED 127.0.0.1:8765' || true\"",
    "dev:fast": "concurrently \"npm run server:dev\" \"vite 2>&1 | grep -v 'ECONNREFUSED 127.0.0.1:8765' || true\"",
    "dev:hot": "./scripts/dev.sh",
    "dev:visual": "npm --silent run build_orchestrator:inner",
    "dev:visual-demo": "npm --silent run simple_visual_build:inner",
    "dev:visual-demo:animate": "npm --silent run simple_visual_build:animate:inner",
    "build_orchestrator:inner": "./scripts/build_orchestrator.sh",
    "simple_visual_build:inner": "./scripts/simple_visual_build.sh",
    "simple_visual_build:animate:inner": "./scripts/simple_visual_build.sh --animate",
    "server": "./start_server.sh",
    "server:dev": "./start_server.sh --dev",
    "server:build": "./start_server.sh --build-only",
    "server:dev:build": "cargo build --bin n-apt-backend",
    "build:wasm": "./build_wasm.sh",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "postinstall": "echo \"ALSO INSTALLING RUST DEPS\" && ./start_server.sh --build-only",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:wasm": "PATH=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/bin:$PATH sh -lc 'cd tests/wasm && wasm-pack test --headless --chrome'",
    "test:rust": "cargo test",
    "test:all": "npm run test && npm run test:rust",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "framer-motion": "^12.34.0",
    "gsap": "^3.14.2",
    "n_apt_canvas": "file:./packages/n_apt_canvas",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "styled-components": "^6.3.8",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.1.2",
    "@webgpu/types": "^0.1.47",
    "concurrently": "^9.2.1",
    "fkill-cli": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "resize-observer-polyfill": "^1.5.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vite": "^7.2.4"
  }
}
