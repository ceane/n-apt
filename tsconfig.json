{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "ES2022.Intl", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@n-apt/*": ["src/ts/*"],
      "@n-apt": ["src/ts"],
      "@n-apt/public/*": ["public/*"],
      "@n-apt/md-preview/*": ["src/md-preview/*"],
      "@n-apt/components/*": ["src/ts/components/*"],
      "@n-apt/fft/*": ["src/ts/fft/*"],
      "@n-apt/waterfall/*": ["src/ts/waterfall/*"],
      "@n-apt/consts": ["src/ts/consts"],
      "@n-apt/hooks/*": ["src/ts/hooks/*"],
      "@n-apt/glb_models/*": ["src/ts/glb_models/*"],
      "@n-apt/encrypted-modules/*": ["src/encrypted-modules/*"],
      "@n-apt/validation": ["src/ts/validation"],
      "@n-apt/validation/*": ["src/ts/validation/*"]
    }
  },
  "include": ["src/ts", "src/md-preview", "src/encrypted-modules", "src/ts/types", "src/types"],
  "exclude": ["src/md-preview/components/canvas/ascii-motion-animation.tsx"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
