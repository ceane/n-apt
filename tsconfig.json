{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@n-apt/*": ["src/*"],
      "@n-apt": ["src"],
      "@n-apt/components/*": ["src/components/*"],
      "@n-apt/fft/*": ["src/fft/*"],
      "@n-apt/waterfall/*": ["src/waterfall/*"],
      "@n-apt/consts": ["src/consts"],
      "@n-apt/hooks/*": ["src/hooks/*"],
      "@n-apt/glb_models/*": ["src/glb_models/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
