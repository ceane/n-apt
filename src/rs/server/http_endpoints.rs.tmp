fn parse_filter_set(raw: &Option<String>) -> HashSet<String> {
  match raw {
    Some(value) => value
      .split(',')
      .map(|v| v.trim())
      .filter(|v| !v.is_empty())
      .map(std::string::ToString::to_string)
      .collect(),
    None => HashSet::new(),
  }
}
