# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE stuff
.vscode
.windsurf

# macOS
.DS_Store

# This is for local links to additional I/Q captures
# Finder aliases (must give them .alias extension)
.alias

# node
node_modules

#build files
dist/
build/
scripts/dist/

# Include scripts/build (don't exclude it)
!scripts/build/


# Rust - exclude all build artifacts and target folders
target/
Cargo.lock
**/target/
!packages/sdr_wasm/target/**/sdr_wasm.wasm

# Rust-specific files
*.pdb
*.profraw
**/*.rs.bk

# Rust toolchain files
rust-toolchain
rust-toolchain.toml
.rustup/

# Rust analyzer
.rust-analyzer/
target/debug/
target/release/
target/rls/
target/cargo-web/dist/

# Swift / Vapor
src/swift-coreml-service/.build/
src/swift-coreml-service/.swiftpm/
src/swift-coreml-service/Package.resolved

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Data files - exclude large zip and dat files
data/*.zip
data/**/*.zip
data/*.dat
data/**/*.dat
data/extracted/*/counts

# Large JSON data files (FCC/OpenCellID processing)
data/json/*.json
data/**/*.json

# Redis data files (already handled in redis/.gitignore)
redis/data/
redis/logs/
redis/backups/
**/*.rdb
**/*.aof
**/appendonlydir/*

# Encrypted modules temporary sources
src/encrypted-modules/tmp/

# Environment variables
.env.local
.env*.local
*storybook.log
storybook-static

